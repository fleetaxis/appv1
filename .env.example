# FleetAxis Local Environment Variables
# ======================================
# Copy this file to ".env" (no extension prefix) and fill in real values.
# NEVER commit .env to git. The .gitignore is set up to prevent this.

# FMCSA QCMobile API key (from mobile.fmcsa.dot.gov)
# Get at: https://mobile.fmcsa.dot.gov  →  Login.gov  →  My WebKeys
FMCSA_WEBKEY=your_fmcsa_webkey_here

# Vercel Postgres connection string
# Auto-populated when you create a Postgres database in Vercel dashboard.
# Vercel will tell you to copy this from Storage → your DB → .env.local tab.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
